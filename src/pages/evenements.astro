---
import BaseLayout from '../layouts/BaseLayout.astro';

const upcomingEvents = [
  {
    title: 'Stage Intensif Salsa et Bachata',
    date: 'A venir',
    description: 'Un week-end complet pour progresser rapidement. Cours du matin et de l\'apres-midi, suivis d\'une partie Sociale le soir.',
    cta: 'Bientot disponibles',
  },
  {
    title: 'Fete de la Dance Orientale',
    date: 'A venir',
    description: 'Spectacle et cours decouverte de belly dance. Ouvert a tous les niveaux, une journee festive pour celebrer cet art millenaire.',
    cta: 'Bientot disponibles',
  },
];

const pastEvents = [
  {
    title: 'Gala Annuel de Dance',
    date: 'Decembre 2024',
    description: 'Notre traditionnel gala fin d\'annee avec les performances des eleves et des professors en Salsa, Bachata, Belly Dance et Danse Orientale.',
    image: 'https://images.unsplash.com/photo-1547153760-18fc86c6f2b3?w=500&q=80',
  },
  {
    title: 'Stag de Saint-Sylvestre',
    date: 'Decembre 2023',
    description: 'Une soiree speciale pour danser le reveillon entre amis. Cours intensifs en matinee et grande soiree de fin d\'annee.',
    image: 'https://images.unsplash.com/photo-1545959570-a940840a4af9?w=500&q=80',
  },
];
---

<BaseLayout title="Evenements" description="Consultez les evenements, stages et spectacles a venir de l'association JAMM Dance ainsi que le recuzil de nos evenements passes." currentPage="/evenements">
  <!-- Page Header -->
  <header class="h-[200px] md:h-[250px] bg-brand-violet flex items-center justify-center relative overflow-hidden">
    <svg class="absolute bottom-0 w-full text-brand-cream" viewBox="0 0 1440 80" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,32 C480,80 960,0 1440,32 L1440,80 L0,80 Z"></path>
    </svg>
    <h1 class="text-white relative z-10">Les Evenements</h1>
  </header>

  <!-- Timeline Section -->
  <section class="section-container" id="timeline">
    <div class="max-w-4xl mx-auto">
      <!-- Tabs: Upcoming / Past -->
      <div class="flex justify-center gap-6 mb-12" role="tablist" aria-label="Filtering les_evenements">
        <button
          role="tab"
          class="px-5 py-2 rounded-full text-sm font-bold border-2 transition-all duration-300 ease-fluid cursor-pointer bg-brand-orange text-white border-brand-orange"
          data-tab="upcoming"
          aria-selected="true"
        >
          A venir
        </button>
        <button
          role="tab"
          class="px-5 py-2 rounded-full text-sm font-bold border-2 transition-all duration-300 ease-fluid cursor-pointer bg-white text-brand-violet border-brand-violet/30 hover:border-brand-violet hover:bg-brand-violet/5"
          data-tab="past"
          aria-selected="false"
        >
          Evenements passes
        </button>
      </div>

      <!-- Upcoming Events Panel -->
      <div class="upcoming-panel relative" role="tabpanel">
        <div class="absolute left-[15px] md:left-8 top-0 bottom-0 w-0.5 bg-gradient-to-b from-brand-violet to-brand-orange" aria-hidden="true"></div>

        {upcomingEvents.map((event, index) => (
          <article class="relative flex gap-6 mb-12 last:mb-0">
            <!-- Timeline Anchor -->
            <div class="absolute left-[7px] md:left-[23px] w-8 h-8 rounded-full bg-brand-violet border-4 border-white shadow flex items-center justify-center flex-shrink-0" aria-hidden="true">
              <span class="text-xs font-bold text-white">{index + 1}</span>
            </div>

            <div class="ml-[51px] md:ml-20 w-full bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow duration-300 ease-fluid">
              <time class="inline-block px-3 py-1 rounded-full bg-brand-orange text-white text-xs font-bold mb-3" datetime="">
                {event.date}
              </time>
              <h2 class="text-xl md:text-2xl mb-2 text-brand-dark">{event.title}</h2>
              <p class="text-brand-dark/70 leading-relaxed mb-4">{event.description}</p>
              <span class="btn-primary text-sm">
                {event.cta}
              </span>
            </div>
          </article>
        ))}
      </div>

      <!-- Past Events Panel (hidden by default) -->
      <div class="past-panel hidden relative" role="tabpanel">
        <div class="absolute left-[15px] md:left-8 top-0 bottom-0 w-0.5 bg-gray-300" aria-hidden="true"></div>

        {pastEvents.map((event, index) => (
          <article class="relative flex gap-6 mb-12 last:mb-0">
            <!-- Timeline Anchor -->
            <div class="absolute left-[7px] md:left-[23px] w-8 h-8 rounded-full bg-gray-400 border-4 border-white shadow flex items-center justify-center flex-shrink-0" aria-hidden="true">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>

            <div class="ml-[51px] md:ml-20 w-full bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300 ease-fluid">
              <img
                src={event.image}
                alt={`Photo de l'evenement ${event.title}`}
                class="w-full h-48 object-cover"
                loading="lazy"
              />
              <div class="p-6">
                <time class="inline-block px-3 py-1 rounded-full bg-gray-300 text-gray-700 text-xs font-bold mb-3" datetime="">
                  {event.date}
                </time>
                <h2 class="text-xl md:text-2xl mb-2 text-brand-dark">{event.title}</h2>
                <p class="text-brand-dark/70 leading-relaxed">{event.description}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Tab Toggle Script -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('[data-tab]');
      const upcomingPanel = document.querySelector('.upcoming-panel');
      const pastPanel = document.querySelector('.past-panel');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.tab;
          tabs.forEach(t => {
            t.classList.remove('bg-brand-orange', 'text-white', 'border-brand-orange');
            t.classList.add('bg-white', 'text-brand-violet', 'border-brand-violet/30');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('bg-brand-orange', 'text-white', 'border-brand-orange');
          tab.classList.remove('bg-white', 'text-brand-violet', 'border-brand-violet/30');
          tab.setAttribute('aria-selected', 'true');

          if (target === 'upcoming') {
            upcomingPanel?.classList.remove('hidden');
            pastPanel?.classList.add('hidden');
          } else {
            upcomingPanel?.classList.add('hidden');
            pastPanel?.classList.remove('hidden');
          }
        });
      });
    });
  </script>

  <!-- CTA Section -->
  <section class="bg-brand-violet py-16 md:py-24 text-center text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-brand-gold mb-4">Ne manquez aucun evenement !</h2>
      <p class="text-lg mb-8 text-white/90">Restez connecte pour recevoir les annonces de stages et spectacles en exclusivite.</p>
      <a href="/cours" class="btn-primary bg-white text-brand-violet hover:bg-brand-gold hover:text-brand-dark shadow-xl">
        S'inscrire aux cours
      </a>
    </div>
  </section>
</BaseLayout>
