---
import BaseLayout from '../layouts/BaseLayout.astro';
import { locations } from '../data/locations';

const phoneDisplay = '07 49 82 88 01';
const phoneTelLink = '+33749828801';
const emailAddress = 'jamm.dance.94@gmail.com';
---

<BaseLayout title="Contact" description="Retrouvez nos coordonnées, lieux de cours et informations pratiques pour nous joindre." currentPage="/contact">
  <main>
    <!-- Page Header -->
    <header class="h-[200px] md:h-[250px] bg-brand-violet flex items-center justify-center relative overflow-hidden">
      <svg class="absolute bottom-0 w-full text-brand-cream" viewBox="0 0 1440 80" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,32 C480,80 960,0 1440,32 L1440,80 L0,80 Z"></path>
      </svg>
      <div class="text-center relative z-10 px-4">
        <h1 class="text-white mb-3">Nous Contacter</h1>
        <p class="text-white/80 max-w-lg mx-auto text-base md:text-lg">
          Une question, une demande d'information ou envie de rejoindre l'association ? N'hésitez pas à nous contacter.
        </p>
      </div>
    </header>

    <!-- Phone & Email Cards -->
    <section class="bg-white py-16 md:py-24">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Phone -->
          <article role="region" aria-label="Téléphone" class="bg-white rounded-lg shadow-md p-8 text-center hover:shadow-xl transition-shadow duration-300 ease-fluid border border-gray-100">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-brand-violet/10 mb-4" aria-hidden="true">
              <svg class="w-8 h-8 text-brand-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <h2 class="font-display font-bold text-xl text-brand-violet mb-3">Téléphone</h2>
            <a href={"tel:" + phoneTelLink} class="text-lg font-semibold text-brand-dark hover:text-brand-violet transition-colors duration-300 ease-fluid">
              {phoneDisplay}
            </a>
          </article>

          <!-- Email -->
          <article role="region" aria-label="Email" class="bg-white rounded-lg shadow-md p-8 text-center hover:shadow-xl transition-shadow duration-300 ease-fluid border border-gray-100">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-brand-violet/10 mb-4" aria-hidden="true">
              <svg class="w-8 h-8 text-brand-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="font-display font-bold text-xl text-brand-violet mb-3">Email</h2>
            <a href={"mailto:" + emailAddress} class="text-lg font-semibold text-brand-dark hover:text-brand-violet transition-colors duration-300 ease-fluid">
              {emailAddress}
            </a>
          </article>
        </div>
      </div>
    </section>

    <!-- Location Cards with Maps -->
    <section class="bg-brand-cream py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-center text-brand-violet mb-12">Nos Lieux</h2>

        <div class="space-y-12" role="list" aria-label="Nos lieux de cours">
          {locations.map((location) => (
            <article role="listitem" aria-label={"Lieu à " + location.name} class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 ease-fluid max-w-4xl mx-auto">
              <!-- Map & Info Grid -->
              <div class="grid grid-cols-1 md:grid-cols-2">
                <!-- Left: Address Detail -->
                <div class="p-8 flex flex-col justify-between">
                  <div>
                    <h3 class="font-display font-bold text-2xl text-brand-violet mb-4">{location.name}</h3>

                    <p class="text-gray-700 flex items-start gap-3" aria-hidden="true">
                      <span>
                        <svg class="w-5 h-5 text-brand-violet mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                      </span>
                      <div>
                        <p class="text-black/70 font-medium">{location.venue}</p>
                        <p class="text-gray-500 text-sm">{location.address}</p>
                      </div>
                    </p>

                    <!-- Trial Class Badge -->
                    <div class="mt-4">
                      <span class="inline-block bg-gradient-to-r from-brand-orange to-brand-gold text-white px-4 py-1.5 rounded-full font-bold text-xs uppercase tracking-wider shadow-sm">
                        {location.trialClass}
                      </span>
                    </div>

                    <!-- Special Classes (if applicable) -->
                    {location.specialClasses ? (
                      <div class="mt-auto mt-4 bg-brand-orange/10 border-l-4 border-brand-orange rounded-r-lg p-3">
                        <p class="text-gray-500 text-sm">
                          <span class="font-bold text-brand-orange">Cours spéciaux :</span> {location.specialClasses}
                        </p>
                      </div>
                    ) : undefined}

                    <!-- Schedule link -->
                    <a
                      href="/inscriptions"
                      class="mt-4 inline-flex items-center gap-2 text-brand-violet font-semibold hover:text-brand-dark transition-colors duration-300 ease-fluid text-sm"
                    >
                      Voir les horaires et tarifs
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  </div>
                </div>

                <!-- Right: Embedded Map -->
                <div class="bg-brand-violet/10">
                  <iframe
                    title={"Carte - " + location.name}
                    src={location.mapsEmbedUrl}
                    width="100%"
                    height="100%"
                    min-height="350"
                    class="border-0"
                    allowfullscreen
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                  />
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 md:py-24">
      <div class="max-w-3xl mx-auto text-center px-4 sm:px-6 lg:px-8">
        <h2 class="font-display font-bold text-2xl md:text-3xl text-brand-violet mb-4">Prêt à débuter ?</h2>
        <p class="text-lg text-brand-dark/70 mb-8 max-w-xl mx-auto">Rejoignez nos cours et découvrez les danses latines ou orientales dans une ambiance chaleureuse.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/inscriptions" class="btn-primary shadow-lg inline-block">Voir les horaires</a>
          <a href="/association" class="inline-flex items-center justify-center px-6 py-3 border-2 border-brand-violet text-brand-violet font-bold uppercase tracking-wide rounded-lg hover:bg-brand-violet hover:text-white transition-all duration-300 ease-fluid">Découvrir l'association</a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
