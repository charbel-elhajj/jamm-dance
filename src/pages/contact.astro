---
import BaseLayout from '../layouts/BaseLayout.astro';

const locations = [
  {
    city: "Thiais",
    venue: "Centre de Loisirs Jules Ferry",
    address_line1: "66, rue Paul Vaillant Couturier",
    postal_code: "94320 THIAIS",
    map_url: "https://www.google.com/maps/search/?api=1&query=66+rue+Paul+Vaillant+Couturier+94320+THIAIS",
  },
  {
    city: "Mandres-les-Roses",
    venue: "Ferme de Monsieur",
    address_line1: "4 rue du General Leclerc",
    postal_code: "94520 MANDRES-LES-ROSES",
    map_url: "https://www.google.com/maps/search/?api=1&query=4+rue+du+General+Leclerc+94520+MANDRES-LES-ROSES",
  },
];

const phone_display = "07 49 82 88 01";
const phone_tel_link = "+33749828801";
const email_address = 'jamm.dance.94@gmail.com';
---

<BaseLayout title="Contact | JAMM Dance" currentPage="/contact">
  <main>
    <section class="py-16 md:py-24 bg-brand-cream">
      <div class="max-w-4xl mx-auto text-center px-4 sm:px-6 lg:px-8">
        <h1 class="font-display font-bold text-4xl md:text-5xl text-brand-violet mb-6">Nous Contacter</h1>
        <p class="text-xl text-brand-dark/70 max-w-2xl mx-auto leading-relaxed">
          Une question, une demande d'information ou envie de rejoindre l'association ? N'hesitez pas a nous contacter directement.
        </p>
      </div>
    </section>

    <section class="py-16 md:py-24">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">

          <article role="region" aria-label="Telephone" class="bg-white rounded-lg shadow-md p-8 text-center hover:shadow-xl transition-shadow duration-300 ease-fluid">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-brand-violet/10 mb-4" aria-hidden="true">
              <svg class="w-8 h-8 text-brand-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <h2 class="font-display font-bold text-xl text-brand-violet mb-3">Telephone</h2>
            <a href={"tel:" + phone_tel_link} class="text-lg font-semibold text-brand-dark hover:text-brand-violet transition-colors duration-300 ease-fluid">
              {phone_display}
            </a>
          </article>

          <article role="region" aria-label="Email" class="bg-white rounded-lg shadow-md p-8 text-center hover:shadow-xl transition-shadow duration-300 ease-fluid">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-brand-violet/10 mb-4" aria-hidden="true">
              <svg class="w-8 h-8 text-brand-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="font-display font-bold text-xl text-brand-violet mb-3">Email</h2>
            <a href={"mailto:" + email_address} class="text-lg font-semibold text-brand-dark hover:text-brand-violet transition-colors duration-300 ease-fluid">
              {email_address}
            </a>
          </article>

        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-brand-cream">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8" role="region" aria-labelledby="locations-heading">
        <h2 id="locations-heading" class="font-display font-bold text-3xl md:text-4xl text-center text-brand-violet mb-12">Nos Lieux</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8" role="list" aria-label="Nos lieux de cours">
          {locations.map((location) => (
            <article role="listitem" aria-label={"A " + location.city} class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 ease-fluid">

              <!-- Map Placeholder -->
              <div class="aspect-video bg-brand-violet/20 relative flex items-center justify-center">
                <a href={location.map_url} target="_blank" rel="noopener noreferrer" class="absolute inset-0 p-4 flex items-center justify-center group" aria-label={"Voir " + location.address_line1 + " sur la carte"}>
                  <svg class="w-24 h-8 text-brand-violet/50 group-hover:text-brand-violet transition-colors duration-300 ease-fluid" aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5zm0-4c-.83 0-1.5.67-1.5 1.5S11.17 9.5s2.5 1.38z" />
                  </svg>
                </a>
              </div>

              <!-- Location Info -->
              <div class="p-6">
                <h3 class="font-display font-bold text-xl text-brand-violet mb-2">A {location.city}</h3>
                <p class="text-brand-dark/90 font-semibold mb-2">{location.venue}</p>
                <address class="not-italic text-sm text-brand-dark/70 space-y-1">
                  <p>{location.address_line1}</p>
                  <p>{location.postal_code}</p>
                </address>

                <a href={location.map_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-4 text-brand-violet font-semibold hover:text-brand-dark transition-colors duration-300 ease-fluid">
                  Voir sur la carte
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V8a2 2 0 00-2-2h-4M3 6h10.5L3 17V6zM13.5 6l4.995 4.995 M13.5 6l4.995 4.995" />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 md:py-24">
      <div class="max-w-3xl mx-auto text-center px-4 sm:px-6 lg:px-8">
        <h2 class="font-display font-bold text-2xl md:text-3xl text-brand-violet mb-4">Prete a debuter ?</h2>
        <p class="text-lg text-brand-dark/70 mb-8 max-w-xl mx-auto">Rejoignez nos cours et decouvrez les danses latines ou orientales dans une ambiance chaleureuse.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/cours" class="btn-primary shadow-lg inline-block">Voir les horaires</a>
          <a href="/association" class="inline-flex items-center justify-center px-6 py-3 border-2 border-brand-violet text-brand-violet font-semibold rounded-lg hover:bg-brand-violet hover:text-white transition-all duration-300 ease-fluid">Decouvrir l'association</a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>