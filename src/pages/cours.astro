---
import BaseLayout from '../layouts/BaseLayout.astro';

const danceStyles = ['Tous', 'Salsa', 'Bachata', 'Belly Dance', 'Danse Orientale'];

const scheduleItems = [
  { style: 'Salsa', day: 'Lundi', time: '18h30 - 20h00', level: 'Tout niveau', instructor: 'A venir' },
  { style: 'Salsa', day: 'Mercredi', time: '19h00 - 20h30', level: 'Intermediaire', instructor: 'A venir' },
  { style: 'Bachata', day: 'Mardi', time: '18h30 - 20h00', level: 'Tout niveau', instructor: 'A venir' },
  { style: 'Bachata', day: 'Jeudi', time: '19h00 - 20h30', level: 'Avance', instructor: 'A venir' },
  { style: 'Belly Dance', day: 'Lundi', time: '20h00 - 21h30', level: 'Debutant', instructor: 'A venir' },
  { style: 'Belly Dance', day: 'Vendredi', time: '18h00 - 19h30', level: 'Tout niveau', instructor: 'A venir' },
  { style: 'Danse Orientale', day: 'Mercredi', time: '18h00 - 19h30', level: 'Intermediaire', instructor: 'A venir' },
];

const pricingCards = [
  { name: 'Pass 5 Cours', price: '45', description: 'Ideal pour decouvrir. Valable 1 mois.', highlight: false },
  { name: 'Carte Mensuelle', price: '65', description: 'Acces illimite a tous les cours du mois.', highlight: true },
  { name: 'Trimestre', price: '170', description: '3 mois d acces illimite. Economisez !', highlight: false },
];
---

<BaseLayout title="Les Cours" description="Consultez les horaires et tarifs de nos cours de dance a Paris : Salsa, Bachata, Belly Dance et Danse Orientale." currentPage="/cours">
  <!-- Page Header -->
  <header class="h-[200px] md:h-[250px] bg-brand-violet flex items-center justify-center relative overflow-hidden">
    <svg class="absolute bottom-0 w-full text-brand-cream" viewBox="0 0 1440 80" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,32 C480,80 960,0 1440,32 L1440,80 L0,80 Z"></path>
    </svg>
    <h1 class="text-white relative z-10">Les Cours</h1>
  </header>

  <!-- Filter Pills -->
  <section class="bg-brand-cream pb-6" id="horaires">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <h2 class="text-brand-violet mb-4 text-center">Horaires des Cours</h2>
      <div class="flex flex-wrap justify-center gap-3" role="group" aria-label="Filtrer par style de dance">
        {danceStyles.map((style, idx) => (
          <button
            class={`px-5 py-2 rounded-full text-sm font-semibold border-2 transition-all duration-300 ease-fluid
              ${idx === 0
                ? 'bg-brand-violet text-white border-brand-violet'
                : 'bg-white text-brand-violet border-brand-violet/30 hover:border-brand-violet hover:bg-brand-violet/5'}`}
            data-filter={style.toLowerCase()}
          >
            {style}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Schedule Table -->
  <section class="section-container">
    <div class="overflow-x-auto rounded-lg shadow-md" role="region" aria-label="Tableau des horaires" tabindex="0">
      <table class="w-full min-w-[600px] bg-white">
        <thead>
          <tr class="bg-brand-violet text-white">
            <th scope="col" class="text-left px-6 py-4 font-bold uppercase tracking-wider text-sm">Style</th>
            <th scope="col" class="text-left px-6 py-4 font-bold uppercase tracking-wider text-sm">Jour</th>
            <th scope="col" class="text-left px-6 py-4 font-bold uppercase tracking-wider text-sm">Horaire</th>
            <th scope="col" class="text-left px-6 py-4 font-bold uppercase tracking-wider text-sm">Niveau</th>
            <th scope="col" class="text-left px-6 py-4 font-bold uppercase tracking-wider text-sm">Professeur</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {scheduleItems.map((item) => (
            <tr class="hover:bg-brand-violet/5 transition-colors duration-200 ease-fluid">
              <td class="px-6 py-4 font-semibold text-brand-violet">{item.style}</td>
              <td class="px-6 py-4 text-gray-700">{item.day}</td>
              <td class="px-6 py-4 text-gray-700">{item.time}</td>
              <td class="px-6 py-4">
                <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold
                  ${item.level === 'Debutant' ? 'bg-green-100 text-green-800' : ''}
                  ${item.level === 'Tout niveau' ? 'bg-blue-100 text-blue-800' : ''}
                  ${item.level === 'Intermediaire' ? 'bg-yellow-100 text-yellow-800' : ''}
                  ${item.level === 'Avance' ? 'bg-red-100 text-red-800' : ''}
                `}>
                  {item.level}
                </span>
              </td>
              <td class="px-6 py-4 text-gray-700">{item.instructor}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Filter Script -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const buttons = document.querySelectorAll('[data-filter]');
        const rows = document.querySelectorAll('tbody tr');
        buttons.forEach(btn => {
          btn.addEventListener('click', () => {
            // Update active state
            buttons.forEach(b => b.classList.remove('bg-brand-violet', 'text-white'));
            buttons.forEach(b => b.classList.add('bg-white', 'text-brand-violet'));
            btn.classList.add('bg-brand-violet', 'text-white');
            btn.classList.remove('bg-white', 'text-brand-violet');

            const filter = btn.dataset.filter;
            rows.forEach(row => {
              if (filter === 'tous') {
                row.style.display = '';
              } else {
                const styleCell = row.querySelector('td:first-child');
                row.style.display = styleCell ? styleCell.textContent.trim().toLowerCase() === filter ? '' : 'none' : '';
              }
            });
          });
        });
      });
    </script>
  </section>

  <!-- Pricing Cards -->
  <section class="bg-white py-16 md:py-24" id="tarifs">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-brand-violet mb-3">Nos Tarifs</h2>
        <p class="text-brand-dark/70 max-w-xl mx-auto">Choisissez la formule qui vous convient pour commencer votre parcours de dance.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
        {pricingCards.map((card) => (
          <article
            class={`rounded-lg p-8 text-center transition-all duration-300 ease-fluid hover:-translate-y-1 hover:shadow-xl
              ${card.highlight
                ? 'bg-gradient-to-br from-brand-orange to-brand-gold text-white shadow-md scale-[1.02]'
                : 'bg-white border border-gray-200'}`}
          >
            <h3 class={`font-bold text-lg mb-2 ${card.highlight ? 'text-white' : 'text-brand-violet'}`}>
              {card.name}
            </h3>
            <div class="my-4">
              <span class="text-4xl font-extrabold">{card.price}</span>
              <span class={`text-sm ${card.highlight ? 'text-white/80' : 'text-gray-500'}`}> EUR</span>
            </div>
            <p class={`text-sm mb-6 ${card.highlight ? 'text-white/90' : 'text-gray-600'}`}>{card.description}</p>
            <a
              href="#"
              class={`w-full inline-block px-6 py-3 rounded-lg font-bold uppercase tracking-wider text-sm transition-all duration-300 ease-fluid hover:scale-105
                ${card.highlight
                  ? 'bg-white text-brand-orange'
                  : 'btn-primary bg-brand-violet hover:bg-brand-orange'}`}
            >
              S'inscrire
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
