---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedEventBanner from '../components/FeaturedEventBanner.astro';

const danceStyles = [
  { name: 'Salsa', image: 'https://images.unsplash.com/photo-1547153760-18fc86c6f2b3?w=600&q=80' },
  { name: 'Bachata', image: 'https://images.unsplash.com/photo-1504609813442-a89a42713e94?w=600&q=80' },
  { name: 'Belly Dance', image: 'https://images.unsplash.com/photo-1518834107812-67c02da4d1ee?w=600&q=80' },
  { name: 'Danse Orientale', image: 'https://images.unsplash.com/photo-1545959570-a940840a4af9?w=600&q=80' },
  { name: 'Zumba', image: 'https://images.unsplash.com/photo-1524594157335-5dfe77ccc1e4?w=600&q=80' },
  { name: "Latin'Ladies", image: 'https://images.unsplash.com/photo-1547153760-18fc86c6f2b3?w=600&q=80' },
  { name: 'Latino Kids', image: 'https://images.unsplash.com/photo-1595435934219-8678b0db3721?w=600&q=80' },
];
---

<BaseLayout title="Accueil" description="JAMM Dance - Association de danse latine et fitness dansant à Thiais et Mandres-les-Roses. Cours de Zumba, Latin'Ladies, Latino Kids, Salsa, Bachata, Belly Dance et Danse Orientale." currentPage="/">
  <!-- Hero Video Section -->
  <section class="relative h-[70vh] md:h-[85vh] overflow-hidden" aria-label="Vidéo de présentation">
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
      poster="https://images.unsplash.com/photo-1547153760-18fc86c6f2b3?w=1600&q=80"
    >
      <source src="https://videos.pexels.com/video-files/3195397/3195397-hd_1920_1080_25fps.mp4" type="video/mp4" />
    </video>
    <!-- Violet Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-brand-violet/40 via-transparent to-brand-violet/60" aria-hidden="true"></div>

    <!-- Hero Content -->
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-center text-white px-4">
      <h1 class="mb-4 drop-shadow-lg">Bienvenue chez JAMM Dance</h1>
      <p class="text-lg md:text-xl max-w-2xl mb-8 drop-shadow-md">
        Revêtez-vous de l'énergie des danses latines et du fitness dansant. Rejoignez notre communauté passionnée à Thiais et Mandres-les-Roses.
      </p>
      <a href="/cours" class="btn-primary shadow-xl">
        Découvrir nos cours
      </a>
    </div>
  </section>

  <!-- Upcoming Event Highlight Banner (dynamic, hidden if no upcoming events) -->
  <FeaturedEventBanner />

  <!-- Dance Matrix Section -->

  <!-- Dance Matrix Section -->
  <section class="section-container" aria-label="Nos styles de danse">
    <div class="text-center mb-12">
      <h2 class="text-brand-violet mb-3">Nos Styles de Danse</h2>
      <p class="text-brand-dark/70 max-w-xl mx-auto">
        Des cours pour tous les niveaux du jeune enfant aux adultes. Trouvez le style qui vous correspond.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" role="list">
      {danceStyles.map(style => (
        <article
          role="listitem"
          class="group relative overflow-hidden rounded-lg shadow-md transition-all duration-300 ease-fluid hover:shadow-xl hover:-translate-y-1"
        >
          <img src={style.image} alt={`Image représentant le style ${style.name}`} class="w-full h-64 object-cover transition-transform duration-500 ease-fluid group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-violet/90 via-brand-violet/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300 ease-fluid"></div>
          <div class="absolute bottom-0 left-0 p-5">
            <h3 class="text-white text-xl font-bold capitalize">{style.name}</h3>
            <p class="text-white/80 text-sm mt-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300 ease-fluid">
              Cliquez pour en savoir plus
            </p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Call to Action Section -->
  <section class="bg-brand-violet py-16 md:py-24 text-center text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-brand-gold mb-4">Prêt à danser ?</h2>
      <p class="text-lg mb-8 text-white/90">Rejoignez JAMM Dance et découvrez une nouvelle facette de vous-même.</p>
      <a href="/cours" class="btn-primary bg-white text-brand-violet hover:bg-brand-gold hover:text-brand-dark shadow-xl">
        S'inscrire dès maintenant
      </a>
    </div>
  </section>
</BaseLayout>
