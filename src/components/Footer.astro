---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-violet text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <!-- Brand Column -->
      <div>
        <a href="/" class="inline-block mb-4">
          <img src="/logo.png" alt="JAMM Dance Logo" class="h-10 w-auto object-contain" />
        </a>
        <p class="text-white/80 leading-relaxed">
          Association de danses latines et orientales.
        </p>
      </div>

      <!-- Quick Links -->
      <nav aria-label="Liens de navigation en pied de page">
        <h3 class="font-display font-bold text-lg uppercase tracking-wider mb-4 text-brand-gold">Navigation</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-white/80 hover:text-white transition-colors duration-300 ease-fluid">Accueil</a></li>
          <li><a href="/association" class="text-white/80 hover:text-white transition-colors duration-300 ease-fluid">L'Association</a></li>
          <li><a href="/inscriptions" class="text-white/80 hover:text-white transition-colors duration-300 ease-fluid">Inscriptions</a></li>
          <li><a href="/professeurs" class="text-white/80 hover:text-white transition-colors duration-300 ease-fluid">Les Professeurs</a></li>
          <li><a href="/evenements" class="text-white/80 hover:text-white transition-colors duration-300 ease-fluid">Événements</a></li>
          <li><a href="/contact" class="text-white/80 hover:text-white transition-colors duration-300 ease-fluid">Contact</a></li>
        </ul>
      </nav>

      <!-- Contact Column -->
      <address class="not-italic">
        <h3 class="font-display font-bold text-lg uppercase tracking-wider mb-4 text-brand-gold">Contact</h3>
        <div class="space-y-3 text-white/80">
          <a href="tel:+33749828801" class="block hover:text-white transition-colors duration-300 ease-fluid">
            07 49 82 88 01
          </a>
          <a href="mailto:jamm.dance.94@gmail.com" class="block hover:text-white transition-colors duration-300 ease-fluid">
            jamm.dance.94@gmail.com
          </a>
          <div class="pt-3 border-t border-white/15 space-y-1 text-sm">
            <p>Thiais - Centre de Loisirs Jules Ferry</p>
            <p>Mandres-les-Roses - Ferme de Monsieur</p>
          </div>
        </div>
      </address>
    </div>

    <!-- Social Media Links -->
    <div class="flex flex-col items-center mt-10">
      <h3 class="font-display font-bold text-sm uppercase tracking-wider mb-4 text-brand-gold">Suivez-nous</h3>
      <div class="flex gap-5">
        <!-- Instagram -->
        <a
          href="https://www.instagram.com/jamm_dance_thiais/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Retrouvez-nous sur Instagram"
          class="text-white/70 hover:text-brand-gold transition-colors duration-300 ease-fluid hover:scale-110 transform"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>

        <!-- Facebook -->
        <a
          href="https://www.facebook.com/p/JAMM-Dance-Thiais-100095212456703/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Retrouvez-nous sur Facebook"
          class="text-white/70 hover:text-brand-gold transition-colors duration-300 ease-fluid hover:scale-110 transform"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-white/15 text-center text-sm">
      <a href="/reglement-interieur-V2.pdf" target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-white transition-colors duration-300 ease-fluid underline underline-offset-4 decoration-white/30">
        Règlement intérieur de l'association
      </a>
      <p class="mt-3">&copy; {currentYear} JAMM Dance. Tous droits réservés.</p>
    </div>
  </div>
</footer>
