---
import type { Event } from '../data/events';
import eventsData from '../data/events.json';

const events: Event[] = eventsData as unknown as Event[];

const today = new Date();
today.setHours(0, 0, 0, 0);

// Find the closest upcoming event
const upcomingEvents = events
  .filter((e) => new Date(e.date) >= today)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const closestEvent = upcomingEvents.length > 0 ? upcomingEvents[0] : null;

// Placeholder fallback images
const PLACEHOLDER_FALLBACKS: Record<string, string> = {
  soiree: 'https://images.unsplash.com/photo-1547153760-18fc86c6f2b3?w=600&q=80',
  stage: 'https://images.unsplash.com/photo-1545959570-a940840a4af9?w=600&q=80',
  autre: 'https://images.unsplash.com/photo-1504609763229-c3bd47d8c0f9?w=600&q=80',
};

if (!closestEvent) {
  // Render nothing when there are no upcoming events
}
---

{closestEvent && (
  <section class="relative -mt-8 z-20 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Evenement a venir">
    <div class="bg-gradient-to-r from-brand-orange to-brand-gold rounded-lg shadow-xl overflow-hidden flex flex-col md:flex-row transition-all duration-300 ease-fluid hover:shadow-2xl">

      <!-- Media side -->
      <div class="relative w-full md:w-64 lg:w-72 h-56 md:h-auto flex-shrink-0 overflow-hidden">
        <img
          src={closestEvent.image || PLACEHOLDER_FALLBACKS[closestEvent.type] || PLACEHOLDER_FALLBACKS.autre}
          alt={`Affiche: ${closestEvent.title}`}
          class="w-full h-full object-cover transition-transform duration-500 ease-fluid hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-transparent to-brand-orange/20 pointer-events-none" aria-hidden="true"></div>
        <!-- Event type badge -->
        <span class="absolute top-4 left-4 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide shadow bg-white/90 text-brand-orange">
          {closestEvent.type === 'stage' ? 'STAGE' : closestEvent.type === 'soiree' ? 'SOIREE' : 'AUTRE'}
        </span>
      </div>

      <!-- Content side -->
      <div class="flex-1 p-6 md:p-8 text-white flex flex-col justify-between">
        <div>
          <span class="inline-block bg-white/20 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-3">
            A ne pas manquer !
          </span>

          <h2 class="text-xl md:text-2xl lg:text-3xl mb-3">{closestEvent.title}</h2>

          <div class="space-y-2 text-white/90 text-sm">
            <!-- Date -->
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <time datetime={closestEvent.date}>{closestEvent.displayDate}</time>
            </div>

            <!-- Time -->
            {closestEvent.time && (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{closestEvent.time}</span>
              </div>
            )}

            <!-- Location -->
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>{closestEvent.location.venue}</span>
            </div>

            <!-- Pricing quick glance -->
            {closestEvent.pricing.length > 0 && (
              <div class="flex items-center gap-2 pt-1">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h.01m2 0h.01M12 12h.01M12 15h.01M15 12h.01M15 15h.01" />
                </svg>
                <span class="text-sm">
                  {closestEvent.pricing.map((item, i) => (
                    <>{i > 0 && ' - '}{item.label}: {item.price}</>
                  ))}
                </span>
              </div>
            )}
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-4 md:mt-6 flex items-center gap-4">
          <a
            href="/evenements"
            class="inline-flex items-center gap-2 bg-white text-brand-orange px-5 py-2.5 rounded-lg font-bold uppercase tracking-wide text-sm transition-all duration-300 ease-fluid hover:bg-brand-dark hover:text-white shadow-md"
          >
            Voir les details
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          {closestEvent.paymentUrl ? (
            <a
              href={closestEvent.paymentUrl}
              class="btn-primary text-sm"
              target="_blank"
              rel="noopener noreferrer"
            >
              S'inscrire
            </a>
          ) : (
            <a
              href={`tel:${closestEvent.contact.replace(/\D/g, '')}`}
              class="btn-primary text-sm"
              target="_blank"
              rel="noopener noreferrer"
            >
              Contacter
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
)}
