---
import { type Event } from '../data/events';
import eventsData from '../data/events.json';

const events: Event[] = eventsData as unknown as Event[];

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcomingEvents = events
  .filter((e) => new Date(e.date) >= today)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
---

{upcomingEvents.length > 0 && (
  <section class="section-container bg-[#FAF7FC] py-16 md:py-24" aria-label="Evenements a venir">
    <div class="max-w-5xl mx-auto">

      <!-- Section Header -->
      <header class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
        <div>
          <span class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-gradient-to-r from-brand-orange to-brand-gold text-white mb-3">
            A ne pas manquer
          </span>
          <h2 class="text-brand-violet mb-2">Les Evènements à Venir</h2>
          <p class="text-brand-dark/60 max-w-lg text-sm leading-relaxed">
            Stages, soirées et rencontres danse.
          </p>
        </div>
        <a
          href="/evenements"
          class="inline-flex items-center gap-2 text-brand-violet font-bold text-sm hover:text-brand-orange transition-colors duration-300 ease-fluid group/link"
          aria-label="Voir tous les evenements"
        >
          Voir la liste complète
          <svg
            class="w-4 h-4 transition-transform duration-300 ease-fluid group-hover/link:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </header>

      <!-- Upcoming Events Stack -->
      <div class="space-y-4">
        {upcomingEvents.map((event: Event) => {
          const typeLabel = event.type === 'stage' ? 'STAGE' : event.type === 'soiree' ? 'SOIREE' : '';

          const badgeClasses = event.type === 'stage'
            ? 'bg-brand-violet text-white'
            : 'bg-gradient-to-r from-brand-orange to-brand-gold text-white';

          const shortDate = event.displayDate.split(' ').slice(-2).join(' ');
          const firstPrice = event.pricing.length > 0 ? event.pricing[0] : null;
          return (
            <a
              href="/evenements"
              class="group flex items-stretch gap-5 p-4 rounded-lg bg-white border border-transparent hover:border-brand-violet/20 hover:shadow-md transition-all duration-300 ease-fluid block"
            >
              <!-- Thumbnail Image -->
              <div class="relative w-24 md:w-28 h-20 md:h-24 flex-shrink-0 rounded overflow-hidden">
                <img
                  src={event.image}
                  alt={`Affiche pour ${event.title}`}
                  class="w-full h-full object-cover transition-transform duration-500 ease-fluid group-hover:scale-110"
                  loading="lazy"
                />
              </div>

              <!-- Divider -->
              <div class="w-px bg-brand-violet/10 flex-shrink-0" aria-hidden="true"></div>

              <!-- Content -->
              <div class="flex-1 min-w-0">
                <header class="flex items-center gap-3 mb-1.5">
                  {event.type !== 'autre' && (
                    <span class={`px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider ${badgeClasses}`}>
                      {typeLabel}
                    </span>
                  )}
                  <time datetime={event.date} class="text-brand-dark/60 text-xs font-semibold">
                    {shortDate}
                  </time>
                </header>

                <h3 class="text-brand-dark font-bold text-sm md:text-base mb-1.5 group-hover:text-brand-violet transition-colors duration-300 ease-fluid truncate">
                  {event.title}
                </h3>

                <div class="text-xs text-brand-dark/50 space-y-1">
                  <!-- Time -->
                  {event.time && (
                    <p>
                      <svg class="w-3 h-3 inline-block mr-1 -mt-0.5 flex-shrink-0 text-brand-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {event.time}
                    </p>
                  )}

                  <!-- Location -->
                  <p>
                    <svg class="w-3 h-3 inline-block mr-1 -mt-0.5 flex-shrink-0 text-brand-violet" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    {event.location.venue}
                  </p>

                  <!-- Price -->
                  {firstPrice && (
                    <p class="font-medium text-brand-dark/70">
                      {firstPrice.label} : <strong>{firstPrice.price}</strong>
                      {event.pricing.length > 1 ? ` & ${event.pricing.length - 1} autre${event.pricing.length > 2 ? 's' : ''} tarif${event.pricing.length > 2 ? 's' : ''}` : ''}
                    </p>
                  )}
                </div>
              </div>

              <!-- Arrow icon -->
              <div class="flex items-center flex-shrink-0 text-brand-violet/15 group-hover:text-brand-violet transition-colors duration-300 ease-fluid">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
)}
