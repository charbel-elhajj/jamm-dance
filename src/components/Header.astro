---
interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const navItems = [
  { label: 'Accueil', href: '/' },
  { label: "L'Association", href: '/association' },
  { label: 'Les Cours', href: '/cours' },
  { label: 'Les Professeurs', href: '/professeurs' },
  { label: 'Evenements', href: '/evenements' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="bg-brand-violet text-white sticky top-0 z-50 shadow-lg">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group transition-all duration-300 ease-fluid" aria-label="JAMM Dance - Accueil">
        <img
          src="/logo.png"
          alt="JAMM Dance Logo"
          class="h-12 w-auto object-contain group-hover:scale-105 transition-transform duration-300 ease-fluid"
        />
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-1 lg:gap-2" role="menubar">
        {navItems.map(item => (
          <li role="none">
            <a
              href={item.href}
              role="menuitem"
              class={`px-3 py-2 rounded-md text-sm font-semibold uppercase tracking-wider transition-all duration-300 ease-fluid
                ${currentPage === item.href
                  ? 'bg-white/15 text-brand-gold'
                  : 'text-white hover:bg-white/10 hover:text-brand-gold'}`}
              aria-current={currentPage === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile Menu Button -->
      <button
        class="md:hidden p-2 rounded-md text-white hover:bg-white/10 transition-colors duration-300 ease-fluid mobile-menu-btn"
        aria-label="Ouvrir le menu de navigation"
        aria-expanded="false"
      >
        <svg class="w-6 h-6 mobile-menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <ul class="hidden md:hidden pb-4 mobile-menu space-y-1" role="menu">
      {navItems.map(item => (
        <li role="none">
          <a
            href={item.href}
            role="menuitem"
            class={`block px-3 py-2 rounded-md text-sm font-semibold uppercase tracking-wider transition-all duration-300 ease-fluid
              ${currentPage === item.href
                ? 'bg-white/15 text-brand-gold'
                : 'text-white hover:bg-white/10 hover:text-brand-gold'}`}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.querySelector('.mobile-menu-btn');
    const menu = document.querySelector('.mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
      });
    }
  });
</script>
