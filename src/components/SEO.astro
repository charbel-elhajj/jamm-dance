---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalOverride?: string;
}

const { title, description, image, canonicalOverride } = Astro.props;

const SITE_URL = 'https://www.jammdance.fr';
const canonicalUrl = canonicalOverride
  ? new URL(canonicalOverride, SITE_URL).href.toString()
  : `${SITE_URL}${Astro.url.pathname}`;
---

<!-- Primary SEO Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph Meta Tags -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:locale" content="fr_FR" />
{image && <meta property="og:image" content={`${SITE_URL}${image}`} />}
